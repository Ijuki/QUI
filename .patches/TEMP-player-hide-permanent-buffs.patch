+            if okObj and durationObj and durationObj.GetRemainingDuration then
+                local okRemain, remaining = pcall(durationObj.GetRemainingDuration, durationObj)
+                if okRemain and IsSafeNumber(remaining) then
+                    return remaining <= 0
+                end
+            end
+        end
+
+        local expirationTime = auraData.expirationTime
+        if IsSafeNumber(expirationTime) then
+            return expirationTime <= 0
+        end
+
+        if duration == nil and expirationTime == nil then
+            return true
+        end
+
+        return false
+    end
